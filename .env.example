# HomeBiz Kids environment variables
# Copy to .env.local for local development. Keep real secrets out of git.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database — required when wiring Prisma/Postgres
# For Supabase runtime/serverless, use the Prisma pooled URL from Connect → ORM/Prisma.
# For local Prisma schema pushes, use Supabase's direct/session URL on port 5432.
DATABASE_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-REGION.pooler.supabase.com:5432/postgres"

# Clerk — parent-owned auth; children remain profiles under a parent account
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
CLERK_WEBHOOK_SECRET=

# Stripe — Phase 2 subscription billing only; never for in-app token economy
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_FAMILY_MONTHLY_PRICE_ID=
STRIPE_FAMILY_YEARLY_PRICE_ID=
STRIPE_SUCCESS_URL=http://localhost:3000/pricing/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://localhost:3000/pricing
STRIPE_PORTAL_RETURN_URL=http://localhost:3000/dashboard/settings

# Uploads — Phase 2 photo proof backend, choose UploadThing or Supabase Storage
UPLOADTHING_TOKEN=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Email — Phase 3 trusted adult invites / transactional messages
RESEND_API_KEY=
EMAIL_FROM="HomeBiz Kids <hello@homebizkids.com>"
